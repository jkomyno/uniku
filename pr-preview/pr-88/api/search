ocs/getting-started","tags":[],"type":"text","url":"/docs/getting-started#every-strategy","content":"`tsid()`"},"168":{"id":"/docs/getting-started-54","page_id":"/docs/getting-started","tags":[],"type":"text","url":"/docs/getting-started#every-strategy","content":"`bigint`"},"169":{"id":"/docs/getting-started-55","page_id":"/docs/getting-started","tags":[],"type":"text","url":"/docs/getting-started#every-strategy","content":"See Choosing an ID for the trade-offs, or open a generator reference when you already know which format you need."},"170":{"id":"/docs/getting-started-56","page_id":"/docs/getting-started","tags":[],"type":"text","url":"/docs/getting-started#why-byte-helpers-exist","content":"UUIDs, ULIDs, TypeIDs, KSUIDs, ObjectIDs, XIDs, and TSIDs have a canonical binary representation. Their `toBytes()` and `fromBytes()` helpers let you store and transport that representation without inventing a second codec."},"171":{"id":"/docs/getting-started-57","page_id":"/docs/getting-started","tags":[],"type":"text","url":"/docs/getting-started#why-byte-helpers-exist","content":"This matters when an ID lives in a binary database column, a compact protocol payload, or a cache key. A UUID, for instance, is 16 bytes instead of its 36-character string form. The helpers also make the string boundary explicit: convert when data leaves your application, preserve bytes where the system already handles bytes."},"172":{"id":"/docs/getting-started-58","page_id":"/docs/getting-started","tags":[],"type":"text","url":"/docs/getting-started#why-byte-helpers-exist","content":"String-native formats do not pretend otherwise. Nanoid and CUID v2 have no canonical byte encoding, so they expose a smaller API."},"173":{"id":"/docs/getting-started-59","page_id":"/docs/getting-started","tags":[],"type":"text","url":"/docs/getting-started#write-into-a-caller-owned-buffer","content":"Binary formats can also write directly into a buffer when an integration already owns the allocation:"},"174":{"id":"/docs/getting-started-60","page_id":"/docs/getting-started","tags":[],"type":"text","url":"/docs/getting-started#write-into-a-caller-owned-buffer","content":"Public inputs are validated. Explicit random bytes and buffer offsets make tests and boundary integrations deterministic without changing the generator's default monotonic state."},"175":{"id":"/docs/guides/choosing-an-id","page_id":"/docs/guides/choosing-an-id","type":"page","content":"Choosing an ID","breadcrumbs":["Docs","Guides"],"tags":[],"url":"/docs/guides/choosing-an-id"},"176":{"id":"/docs/guides/choosing-an-id-0","page_id":"/docs/guides/choosing-an-id","tags":[],"type":"text","url":"/docs/guides/choosing-an-id","content":"Choose for the system boundary, not the trend."},"177":{"id":"/docs/guides/choosing-an-id-1","page_id":"/docs/guides/choosing-an-id","type":"heading","tags":[],"url":"/docs/guides/choosing-an-id#a-good-default","content":"A good default"},"178":{"id":"/docs/guides/choosing-an-id-2","page_id":"/docs/guides/choosing-an-id","type":"heading","tags":[],"url":"/docs/guides/choosing-an-id#time-ordering-is-local","content":"Time ordering is local"},"179":{"id":"/docs/guides/choosing-an-id-3","page_id":"/docs/guides/choosing-an-id","type":"heading","tags":[],"url":"/docs/guides/choosing-an-id#time-order-leaks-creation-time","content":"Time order leaks creation time"},"180":{"id":"/docs/guides/choosing-an-id-4","page_id":"/docs/guides/choosing-an-id","tags":[],"type":"text","url":"/docs/guides/choosing-an-id","content":"Different identifiers optimize for different constraints. Start with the boundary the value crosses: database index, URL, public API, MongoDB collection, or a native integer column."},"181":{"id":"/docs/guides/choosing-an-id-5","page_id":"/docs/guides/choosing-an-id","tags":[],"type":"text","url":"/docs/guides/choosing-an-id","content":"Situation"},"182":{"id":"/docs/guides/choosing-an-id-6","page_id":"/docs/guides/choosing-an-id","tags":[],"type":"text","url":"/docs/guides/choosing-an-id","content":"Choose"},"183":{"id":"/docs/guides/choosing-an-id-7","page_id":"/docs/guides/choosing-an-id","tags":[],"type":"text","url":"/docs/guides/choosing-an-id","content":"Why"},"184":{"id":"/docs/guides/choosing-an-id-8","page_id":"/docs/guides/choosing-an-id","tags":[],"type":"text","url":"/docs/guides/choosing-an-id","content":"Database primary keys"},"185":{"id":"/docs/guides/choosing-an-id-9","page_id":"/docs/guides/choosing-an-id","tags":[],"type":"text","url":"/docs/guides/choosing-an-id","content":"UUID v7 or ULID"},"186":{"id":"/docs/guides/choosing-an-id-10","page_id":"/docs/guides/choosing-an-id","tags":[],"type":"text","url":"/docs/guides/choosing-an-id","content":"Time-ordered values improve index locality."},"187":{"id":"/docs/guides/choosing-an-id-11","page_id":"/docs/guides/choosing-an-id","tags":[],"type":"text","url":"/docs/guides/choosing-an-id","content":"Public API resources"},"188":{"id":"/docs/guides/choosing-an-id-12","page_id":"/docs/guides/choosing-an-id","tags":[],"type":"text","url":"/docs/guides/choosing-an-id","content":"TypeID"},"189":{"id":"/docs/guides/choosing-an-id-13","page_id":"/docs/guides/choosing-an-id","tags":[],"type":"text","url":"/docs/guides/choosing-an-id","content":"UUID v7 with a readable, domain-specific prefix."},"190":{"id":"/docs/guides/choosing-an-id-14","page_id":"/docs/guides/choosing-an-id","tags":[],"type":"text","url":"/docs/guides/choosing-an-id","content":"Short URLs and invite codes"},"191":{"id":"/docs/guides/choosing-an-id-15","page_id":"/docs/guides/choosing-an-id","tags":[],"type":"text","url":"/docs/guides/choosing-an-id","content":"Nanoid"},"192":{"id":"/docs/guides/choosing-an-id-16","page_id":"/docs/guides/choosing-an-id","tags":[],"type":"text","url":"/docs/guides/choosing-an-id","content":"Compact and URL-safe."},"193":{"id":"/docs/guides/choosing-an-id-17","page_id":"/docs/guides/choosing-an-id","tags":[],"type":"text","url":"/docs/guides/choosing-an-id","content":"Values that should resist enumeration"},"194":{"id":"/docs/guides/choosing-an-id-18","page_id":"/docs/guides/choosing-an-id","tags":[],"type":"text","url":"/docs/guides/choosing-an-id","content":"CUID v2"},"195":{"id":"/docs/guides/choosing-an-id-19","page_id":"/docs/guides/choosing-an-id","tags":[],"type":"text","url":"/docs/guides/choosing-an-id","content":"Non-sequential, secure identifier."},"196":{"id":"/docs/guides/choosing-an-id-20","page_id":"/docs/guides/choosing-an-id","tags":[],"type":"text","url":"/docs/guides/choosing-an-id","content":"MongoDB `_id` compatibility"},"197":{"id":"/docs/guides/choosing-an-id-21","page_id":"/docs/guides/choosing-an-id","tags":[],"type":"text","url":"/docs/guides/choosing-an-id","content":"ObjectID"},"198":{"id":"/docs/guides/choosing-an-id-22","page_id":"/docs/guides/choosing-an-id","tags":[],"type":"text","url":"/docs/guides/choosing-an-id","content":"Matches MongoDB's 12-byte ObjectID format."},"199":{"id":"/docs/guides/choosing-an-id-23","page_id":"/docs/guides/choosing-an-id","tags":[],"type":"text","url":"/docs/guides/choosing-an-id","content":"Go rs/xid compatibility"},"200":{"id":"/docs/guides/choosing-an-id-24","page_id":"/docs/guides/choosing-an-id","tags":[],"type":"text","url":"/docs/guides/choosing-an-id","content":"XID"},"201":{"id":"/docs/guides/choosing-an-id-25","page_id":"/docs/guides/choosing-an-id","tags":[],"type":"text","url":"/docs/guides/choosing-an-id","content":"Matches rs/xid's compact 12-byte text and binary format."},"202":{"id":"/docs/guides/choosing-an-id-26","page_id":"/docs/guides/choosing-an-id","tags":[],"type":"text","url":"/docs/guides/choosing-an-id","content":"Native `BIGINT` storage"},"203":{"id":"/docs/guides/choosing-an-id-27","page_id":"/docs/guides/choosing-an-id","tags":[],"type":"text","url":"/docs/guides/choosing-an-id","content":"TSID"},"204":{"id":"/docs/guides/choosing-an-id-28","page_id":"/docs/guides/choosing-an-id","tags":[],"type":"text","url":"/docs/guides/choosing-an-id","content":"A sortable 64-bit integer, not a UUID-shaped string."},"205":{"id":"/docs/guides/choosing-an-id-29","page_id":"/docs/guides/choosing-an-id","tags":[],"type":"text","url":"/docs/guides/choosing-an-id","content":"Broad standards compatibility"},"206":{"id":"/docs/guides/choosing-an-id-30","page_id":"/docs/guides/choosing-an-id","tags":[],"type":"text","url":"/docs/guides/choosing-an-id","content":"UUID v4"},"207":{"id":"/docs/guides/choosing-an-id-31","page_id":"/docs/guides/choosing-an-id","tags":[],"type":"text","url":"/docs/guides/choosing-an-id","content":"The conventional random UUID format."},"208":{"id":"/docs/guides/choosing-an-id-32","page_id":"/docs/guides/choosing-an-id","tags":[],"type":"text","url":"/docs/guides/choosing-an-id#a-good-default","content":"If you create records in more than one service or need an ID before inserting a row, start with UUID v7. It is a UUID-native value, sort-friendly, and uses a familiar database column type."},"209":{"id":"/docs/guides/choosing-an-id-33","page_id":"/docs/guides/choosing-an-id","tags":[],"type":"text","url":"/docs/guides/choosing-an-id#time-ordering-is-local","content":"UUID v7, ULID, ObjectID, XID, and TSID carry time information. uniku keeps the state required for monotonic sequencing inside one JavaScript isolate; it does not coordinate clocks or sequences between processes or machines."},"210":{"id":"/docs/guides/choosing-an-id-34","page_id":"/docs/guides/choosing-an-id","tags":[],"type":"text","url":"/docs/guides/choosing-an-id#time-order-leaks-creation-time","content":"UUID v7, ULID, KSUID, ObjectID, XID, and TSID embed a creation timestamp in the identifier itself. Anyone who can read the ID can decode when the record was created, not just its order relative to other records. That is a feature for index locality and a leak if the ID is public and the creation time is sensitive, for example a document, invoice, or account that should not reveal how old it is. If the identifier is exposed outside your system and creation time must stay private, use UUID v4, CUID v2, or Nanoid instead: none of them encode a timestamp."},"211":{"id":"/docs/guides/integrations","page_id":"/docs/guides/integrations","type":"page","content":"Integrations","breadcrumbs":["Docs","Guides"],"tags":[],"url":"/docs/guides/integrations"},"212":{"id":"/docs/guides/integrations-0","page_id":"/docs/guides/integrations","tags":[],"type":"text","url":"/docs/guides/integrations","content":"Runnable starting points for Hono, Drizzle ORM v1, and Effect v4."},"213":{"id":"/docs/guides/integrations-1","page_id":"/docs/guides/integrations","type":"heading","tags":[],"url":"/docs/guides/integrations#hono-request-ids-with-nanoid","content":"Hono request IDs with Nanoid"},"214":{"id":"/docs/guides/integrations-2","page_id":"/docs/guides/integrations","type":"heading","tags":[],"url":"/docs/guides/integrations#drizzle-orm-v1-with-binary-ulids","content":"Drizzle ORM v1 with binary ULIDs"},"215":{"id":"/docs/guides/integrations-3","page_id":"/docs/guides/integrations","type":"heading","tags":[],"url":"/docs/guides/integrations#effect-v4-services-with-typeid","content":"Effect v4 services with TypeID"},"216":{"id":"/docs/guides/integrations-4","page_id":"/docs/guides/integrations","tags":[],"type":"text","url":"/docs/guides/integrations","content":"These examples are the complete Bun test files from the `uniku` repository. Clone the repository and run `pnpm examples:check` to typecheck and execute all three with the Bun version pinned in `mise.toml`."},"217":{"id":"/docs/guides/integrations-5","page_id":"/docs/guides/integrations","tags":[],"type":"text","url":"/docs/guides/integrations#hono-request-ids-with-nanoid","content":"Hono's request ID middleware accepts a synchronous `generator`. When a request does not already carry a valid `X-Request-Id` header, this example generates a compact Nanoid, stores it in the request context, and returns it in the response header."},"218":{"id":"/docs/guides/integrations-6","page_id":"/docs/guides/integrations","tags":[],"type":"text","url":"/docs/guides/integrations#hono-request-ids-with-nanoid","content":"Run it with `pnpm --filter @uniku/examples example:hono`."},"219":{"id":"/docs/guides/integrations-7","page_id":"/docs/guides/integrations","tags":[],"type":"text","url":"/docs/guides/integrations#drizzle-orm-v1-with-binary-ulids","content":"`ulid.toBytes()` produces the canonical 16-byte representation as a runtime-neutral `Uint8Array`. Drizzle v1's built-in PostgreSQL `bytea()` type is Node.js-specific, so this example declares a small `customType` that maps `bytea` directly to `Uint8Array` instead."},"220":{"id":"/docs/guides/integrations-8","page_id":"/docs/guides/integrations","tags":[],"type":"text","url":"/docs/guides/integrations#drizzle-orm-v1-with-binary-ulids","content":"The column's `$defaultFn` generates the binary ULID when an insert omits `id`. The example uses an in-memory PGlite database, so it needs no external PostgreSQL server; it inserts one event, reads the returned 16 bytes, and restores the canonical ULID string with `ulid.fromBytes()`."},"221":{"id":"/docs/guides/integrations-9","page_id":"/docs/guides/integrations","tags":[],"type":"text","url":"/docs/guides/integrations#drizzle-orm-v1-with-binary-ulids","content":"Run it with `pnpm --filter @uniku/examples example:drizzle`."},"222":{"id":"/docs/guides/integrations-10","page_id":"/docs/guides/integrations","tags":[],"type":"text","url":"/docs/guides/integrations#drizzle-orm-v1-with-binary-ulids","content":":::note\nThe example pins Drizzle ORM `1.0.0-rc.4`. The v1 line is still a release candidate, so check its release notes before changing that version.\n:::"},"223":{"id":"/docs/guides/integrations-11","page_id":"/docs/guides/integrations","tags":[],"type":"text","url":"/docs/guides/integrations#effect-v4-services-with-typeid","content":"An Effect service keeps ID generation injectable without leaking framework types into the generated value. This service exposes a traced `next()` effect and returns TypeID strings with a stable `user_` prefix."},"224":{"id":"/docs/guides/integrations-12","page_id":"/docs/guides/integrations","tags":[],"type":"text","url":"/docs/guides/integrations#effect-v4-services-with-typeid","content":"Run it with `pnpm --filter @uniku/examples example:effect`."},"225":{"id":"/docs/guides/integrations-13","page_id":"/docs/guides/integrations","tags":[],"type":"text","url":"/docs/guides/integrations#effect-v4-services-with-typeid","content":":::note\nThis example uses the same exact Effect v4 beta as the `uniku` CLI. Effect v4 is still prerelease software, so keep the example aligned with the workspace pin.\n:::"},"226":{"id":"/docs/guides/performance","page_id":"/docs/guides/performance","type":"page","content":"Performance and bundle size","breadcrumbs":["Docs","Guides"],"tags":[],"url":"/docs/guides/performance"},"227":{"id":"/docs/guides/performance-0","page_id":"/docs/guides/performance","tags":[],"type":"text","url":"/docs/guides/performance","content":"Where uniku beats npm alternatives, where it does not, and what each import weighs."},"228":{"id":"/docs/guides/performance-1","page_id":"/docs/guides/performance","type":"heading","tags":[],"url":"/docs/guides/performance#generation-speed","content":"Generation speed"},"229":{"id":"/docs/guides/performance-2","page_id":"/docs/guides/performance","type":"heading","tags":[],"url":"/docs/guides/performance#bundle-size","content":"Bundle size"},"230":{"id":"/docs/guides/performance-3","page_id":"/docs/guides/performance","type":"heading","tags":[],"url":"/docs/guides/performance#reproduce-these-numbers","content":"Reproduce these numbers"},"231":{"id":"/docs/guides/performance-4","page_id":"/docs/guides/performance","tags":[],"type":"text","url":"/docs/guides/performance","content":"The numbers below come from the repository's own benchmark and bundle-size tooling, including the rows where an npm alternative wins. Benchmarks run in CI on every push to `main` (GitHub Actions, `ubuntu-latest`), so they reflect ordinary Node.js execution rather than a tuned environment."},"232":{"id":"/docs/guides/performance-5","page_id":"/docs/guides/performance","tags":[],"type":"text","url":"/docs/guides/performance#generation-speed","content":"Each row compares uniku's generator against the npm package it targets: `uuid` for UUID v4/v7, `ulid`, `@paralleldrive/cuid2`, `@owpz/ksuid`, `bson` for ObjectID, `nexid` for XID, `tsid-ts`, `nanoid`, and `typeid-js`."},"233":{"id":"/docs/guides/performance-6","page_id":"/docs/guides/performance","tags":[],"type":"text","url":"/docs/guides/performance#generation-speed","content":"This snapshot comes from the rolling `main` baseline updated on July 14, 2026. Treat the ratios as directional: shared-runner noise and dependency updates can move them. The live baseline is the current source of truth."},"234":{"id":"/docs/guides/performance-7","page_id":"/docs/guides/performance","tags":[],"type":"text","url":"/docs/guides/performance#generation-speed","content":"Generator"},"235":{"id":"/docs/guides/performance-8","page_id":"/docs/guides/performance","tags":[],"type":"text","url":"/docs/guides/performance#generation-speed","content":"uniku vs npm"},"236":{"id":"/docs/guides/performance-9","page_id":"/docs/guides/performance","tags":[],"type":"text","url":"/docs/guides/performance#generation-speed","content":"ULID"},"237":{"id":"/docs/guides/performance-10","page_id":"/docs/guides/performance","tags":[],"type":"text","url":"/docs/guides/performance#generation-speed","content":"116× faster"},"238":{"id":"/docs/guides/performance-11","page_id":"/docs/guides/performance","tags":[],"type":"text","url":"/docs/guides/performance#generation-speed","content":"UUID v7"},"239":{"id":"/docs/guides/performance-12","page_id":"/docs/guides/performance","tags":[],"type":"text","url":"/docs/guides/performance#generation-speed","content":"6.4× faster"},"240":{"id":"/docs/guides/performance-13","pag