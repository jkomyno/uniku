/choosing-an-id-23","page_id":"/docs/guides/choosing-an-id","tags":[],"type":"text","url":"/docs/guides/choosing-an-id","content":"Native `BIGINT` storage"},"192":{"id":"/docs/guides/choosing-an-id-24","page_id":"/docs/guides/choosing-an-id","tags":[],"type":"text","url":"/docs/guides/choosing-an-id","content":"TSID"},"193":{"id":"/docs/guides/choosing-an-id-25","page_id":"/docs/guides/choosing-an-id","tags":[],"type":"text","url":"/docs/guides/choosing-an-id","content":"A sortable 64-bit integer, not a UUID-shaped string."},"194":{"id":"/docs/guides/choosing-an-id-26","page_id":"/docs/guides/choosing-an-id","tags":[],"type":"text","url":"/docs/guides/choosing-an-id","content":"Broad standards compatibility"},"195":{"id":"/docs/guides/choosing-an-id-27","page_id":"/docs/guides/choosing-an-id","tags":[],"type":"text","url":"/docs/guides/choosing-an-id","content":"UUID v4"},"196":{"id":"/docs/guides/choosing-an-id-28","page_id":"/docs/guides/choosing-an-id","tags":[],"type":"text","url":"/docs/guides/choosing-an-id","content":"The conventional random UUID format."},"197":{"id":"/docs/guides/choosing-an-id-29","page_id":"/docs/guides/choosing-an-id","tags":[],"type":"text","url":"/docs/guides/choosing-an-id#a-good-default","content":"If you create records in more than one service or need an ID before inserting a row, start with UUID v7. It is a UUID-native value, sort-friendly, and uses a familiar database column type."},"198":{"id":"/docs/guides/choosing-an-id-30","page_id":"/docs/guides/choosing-an-id","tags":[],"type":"text","url":"/docs/guides/choosing-an-id#time-ordering-is-local","content":"UUID v7, ULID, ObjectID, and TSID carry time information. uniku keeps the state required for monotonic sequencing inside one JavaScript isolate; it does not coordinate clocks or sequences between processes or machines."},"199":{"id":"/docs/guides/choosing-an-id-31","page_id":"/docs/guides/choosing-an-id","tags":[],"type":"text","url":"/docs/guides/choosing-an-id#time-order-leaks-creation-time","content":"UUID v7, ULID, KSUID, TSID, and ObjectID embed a creation timestamp in the identifier itself. Anyone who can read the ID can decode when the record was created, not just its order relative to other records. That is a feature for index locality and a leak if the ID is public and the creation time is sensitive, for example a document, invoice, or account that should not reveal how old it is. If the identifier is exposed outside your system and creation time must stay private, use UUID v4, CUID v2, or Nanoid instead: none of them encode a timestamp."},"200":{"id":"/docs/guides/performance","page_id":"/docs/guides/performance","type":"page","content":"Performance and bundle size","breadcrumbs":["Docs","Guides"],"tags":[],"url":"/docs/guides/performance"},"201":{"id":"/docs/guides/performance-0","page_id":"/docs/guides/performance","tags":[],"type":"text","url":"/docs/guides/performance","content":"Where uniku beats npm alternatives, where it does not, and what each import weighs."},"202":{"id":"/docs/guides/performance-1","page_id":"/docs/guides/performance","type":"heading","tags":[],"url":"/docs/guides/performance#generation-speed","content":"Generation speed"},"203":{"id":"/docs/guides/performance-2","page_id":"/docs/guides/performance","type":"heading","tags":[],"url":"/docs/guides/performance#bundle-size","content":"Bundle size"},"204":{"id":"/docs/guides/performance-3","page_id":"/docs/guides/performance","type":"heading","tags":[],"url":"/docs/guides/performance#reproduce-these-numbers","content":"Reproduce these numbers"},"205":{"id":"/docs/guides/performance-4","page_id":"/docs/guides/performance","tags":[],"type":"text","url":"/docs/guides/performance","content":"The numbers below come from the repository's own benchmark and bundle-size tooling, reproduced faithfully including the rows where an npm alternative wins. They run in CI on every push to `main` (GitHub Actions, `ubuntu-latest`), so they reflect ordinary Node.js execution 