s","content":"A byte array or buffer is too short, or an offset is out of bounds."},"351":{"id":"/docs/reference/errors-20","page_id":"/docs/reference/errors","tags":[],"type":"text","url":"/docs/reference/errors#error-classes","content":"`InvalidInputError`, `ParseError`, and `BufferError` each carry a `code: string`, a generator-prefixed constant such as `'UUID_RANDOM_BYTES_TOO_SHORT'` or `'TSID_NODE_OUT_OF_RANGE'`, plus the inherited `message: string`."},"352":{"id":"/docs/reference/errors-21","page_id":"/docs/reference/errors","tags":[],"type":"text","url":"/docs/reference/errors#error-classes","content":"Most generator modules re-export all four classes, so you rarely need to import from `uniku/errors` directly. Nanoid and CUID v2, which have no binary codec, only re-export `InvalidInputError` and `UniqueIdError`."},"353":{"id":"/docs/reference/errors-22","page_id":"/docs/reference/errors","tags":[],"type":"text","url":"/docs/reference/errors#generator-list","content":"`uniku/generators` exports the canonical, ordered list of ID kinds uniku supports:"},"354":{"id":"/docs/reference/errors-23","page_id":"/docs/reference/errors","tags":[],"type":"text","url":"/docs/reference/errors#generator-list","content":"`IdGenerator` is the union type derived from `ID_GENERATORS`. Tools that enumerate or validate generator kinds, such as `@uniku/cli`'s `--type` flag, should derive from this array instead of hand-copying the union."},"355":{"id":"/docs/reference/ksuid","page_id":"/docs/reference/ksuid","type":"page","content":"KSUID","breadcrumbs":["Docs","Reference"],"tags":[],"url":"/docs/reference/ksuid"},"356":{"id":"/docs/reference/ksuid-0","page_id":"/docs/reference/ksuid","tags":[],"type":"text","url":"/docs/reference/ksuid","content":"Time-ordered identifiers with a 128-bit random payload."},"357":{"id":"/docs/reference/ksuid-1","page_id":"/docs/reference/ksuid","tags":[],"type":"text","url":"/docs/reference/ksuid","content":"KSUID combines a timestamp with a large random payload. Choose it for high-volume distributed systems that need chronological order and a 27-character URL-safe string."},"358":{"id":"/docs/reference/nanoid","page_id":"/docs/reference/nanoid","type":"page","content":"Nanoid","breadcrumbs":["Docs","Reference"],"tags":[],"url":"/docs/reference/nanoid"},"359":{"id":"/docs/reference/nanoid-0","page_id":"/docs/reference/nanoid","tags":[],"type":"text","url":"/docs/reference/nanoid","content":"Compact, URL-safe random strings with configurable length and alphabet."},"360":{"id":"/docs/reference/nanoid-1","page_id":"/docs/reference/nanoid","tags":[],"type":"text","url":"/docs/reference/nanoid","content":"Nanoid is the compact choice for short URLs, invite codes, and session tokens. Its default alphabet is URL-safe; pass a length or options only when the boundary needs a different shape."},"361":{"id":"/docs/reference/nanoid-2","page_id":"/docs/reference/nanoid","tags":[],"type":"text","url":"/docs/reference/nanoid","content":"`nanoid.isValid()` validates the default alphabet, not values generated with a custom alphabet."},"362":{"id":"/docs/reference/objectid","page_id":"/docs/reference/objectid","type":"page","content":"ObjectID","breadcrumbs":["Docs","Reference"],"tags":[],"url":"/docs/reference/objectid"},"363":{"id":"/docs/reference/objectid-0","page_id":"/docs/reference/objectid","tags":[],"type":"text","url":"/docs/reference/objectid","content":"MongoDB-compatible 12-byte identifiers."},"364":{"id":"/docs/reference/objectid-1","page_id":"/docs/reference/objectid","tags":[],"type":"text","url":"/docs/reference/objectid","content":"ObjectID matches MongoDB's native 12-byte representation. Use it when your application stores `_id` values alongside MongoDB clients or needs to preserve that wire format."},"365":{"id":"/docs/reference/tsid","page_id":"/docs/reference/tsid","type":"page","content":"TSID","breadcrumbs":["Docs","Reference"],"tags":[],"url":"/docs/reference/tsid"},"366":{"id":"/docs/reference/tsid-0","page_id":"/docs/reference/tsid","tags":[],"type":"text","url":"/docs/reference/tsid","content":"Time-sorted 64-bit identifiers for native bigint storage."},"367":{"id":"/docs/reference/tsid-1","page_id":"/docs/reference/tsid","tags":[],"type":"text","url":"/docs/reference/tsid","content":"TSID returns a `bigint`, not a string. Use it when a database `BIGINT` primary key is the natural representation and you still need time ordering without a central allocator."},"368":{"id":"/docs/reference/typeid","page_id":"/docs/reference/typeid","type":"page","content":"TypeID","breadcrumbs":["Docs","Reference"],"tags":[],"url":"/docs/reference/typeid"},"369":{"id":"/docs/reference/typeid-0","page_id":"/docs/reference/typeid","tags":[],"type":"text","url":"/docs/reference/typeid","content":"UUID v7 identifiers with a readable, domain-specific prefix."},"370":{"id":"/docs/reference/typeid-1","page_id":"/docs/reference/typeid","tags":[],"type":"text","url":"/docs/reference/typeid","content":"TypeID wraps a UUID v7 suffix in a lowercase prefix such as `user_` or `order_`. It is useful when a public identifier should reveal the kind of resource it identifies."},"371":{"id":"/docs/reference/ulid","page_id":"/docs/reference/ulid","type":"page","content":"ULID","breadcrumbs":["Docs","Reference"],"tags":[],"url":"/docs/reference/ulid"},"372":{"id":"/docs/reference/ulid-0","page_id":"/docs/reference/ulid","tags":[],"type":"text","url":"/docs/reference/ulid","content":"Sortable, URL-safe identifiers using Crockford Base32."},"373":{"id":"/docs/reference/ulid-1","page_id":"/docs/reference/ulid","tags":[],"type":"text","url":"/docs/reference/ulid","content":"ULIDs sort by creation time and stay shorter than a hyphenated UUID. Use them when the value will often appear in URLs, logs, or APIs."},"374":{"id":"/docs/reference/uuid-v4","page_id":"/docs/reference/uuid-v4","type":"page","content":"UUID v4","breadcrumbs":["Docs","Reference"],"tags":[],"url":"/docs/reference/uuid-v4"},"375":{"id":"/do