3","page_id":"/docs/getting-started","tags":[],"type":"text","url":"/docs/getting-started#why-byte-helpers-exist","content":"This matters when an ID lives in a binary database column, a compact protocol payload, or a cache key. A UUID, for instance, is 16 bytes instead of its 36-character string form. The helpers also make the string boundary explicit: convert when data leaves your application, preserve bytes where the system already handles bytes."},"164":{"id":"/docs/getting-started-54","page_id":"/docs/getting-started","tags":[],"type":"text","url":"/docs/getting-started#why-byte-helpers-exist","content":"String-native formats do not pretend otherwise. Nanoid and CUID v2 have no canonical byte encoding, so they expose a smaller API."},"165":{"id":"/docs/getting-started-55","page_id":"/docs/getting-started","tags":[],"type":"text","url":"/docs/getting-started#write-into-a-caller-owned-buffer","content":"Binary formats can also write directly into a buffer when an integration already owns the allocation:"},"166":{"id":"/docs/getting-started-56","page_id":"/docs/getting-started","tags":[],"type":"text","url":"/docs/getting-started#write-into-a-caller-owned-buffer","content":"Public inputs are validated. Explicit random bytes and buffer offsets make tests and boundary integrations deterministic without changing the generator's default monotonic state."},"167":{"id":"/docs/guides/choosing-an-id","page_id":"/docs/guides/choosing-an-id","type":"page","content":"Choosing an ID","breadcrumbs":["Docs","Guides"],"tags":[],"url":"/docs/guides/choosing-an-id"},"168":{"id":"/docs/guides/choosing-an-id-0","page_id":"/docs/guides/choosing-an-id","tags":[],"type":"text","url":"/docs/guides/choosing-an-id","content":"Choose for the system boundary, not the trend."},"169":{"id":"/docs/guides/choosing-an-id-1","page_id":"/docs/guides/choosing-an-id","type":"heading","tags":[],"url":"/docs/guides/choosing-an-id#a-good-default","content":"A good default"},"170":{"id":"/docs/guides/choosing-an-id-2","page_id":"/docs/guides/choosing-an-id","type":"heading","tags":[],"url":"/docs/guides/choosing-an-id#time-ordering-is-local","content":"Time ordering is local"},"171":{"id":"/docs/guides/choosing-an-id-3","page_id":"/docs/guides/choosing-an-id","type":"heading","tags":[],"url":"/docs/guides/choosing-an-id#time-order-leaks-creation-time","content":"Time order leaks creation time"},"172":{"id":"/docs/guides/choosing-an-id-4","page_id":"/docs/guides/choosing-an-id","tags":[],"type":"text","url":"/docs/guides/choosing-an-id","content":"Different identifiers optimize for different constraints. Start with the boundary the value crosses: database index, URL, public API, MongoDB collection, or a native integer column."},"173":{"id":"/docs/guides/choosing-an-id-5","page_id":"/docs/guides/choosing-an-id","tags":[],"type":"text","url":"/docs/guides/choosing-an-id","content":"Situation"},"174":{"id":"/docs/guides/choosing-an-id-6","page_id":"/docs/guides/choosing-an-id","tags":[],"type":"text","url":"/docs/guides/choosing-an-id","content":"Choose"},"175":{"id":"/docs/guides/choosing-an-id-7","page_id":"/docs/guides/choosing-an-id","tags":[],"type":"text","url":"/docs/guides/choosing-an-id","content":"Why"},"176":{"id":"/docs/guides/choosing-an-id-8","page_id":"/docs/guides/choosing-an-id","tags":[],"type":"text","url":"/docs/guides/choosing-an-id","content":"Database primary keys"},"177":{"id":"/docs/guides/choosing-an-id-9","page_id":"/docs/guides/choosing-an-id","tags":[],"type":"text","url":"/docs/guides/choosing-an-id","content":"UUID v7 or ULID"},"178":{"id":"/docs/guides/choosing-an-id-10","page_id":"/docs/guides/choosing-an-id","tags":[],"type":"text","url":"/docs/guides/choosing-an-id","content":"Time-ordered values improve index locality."},"179":{"id":"/docs/guides/choosing-an-id-11","page_id":"/docs/guides/choosing-an-id","tags":[],"type":"text","url":"/docs/guides/choosing-an-id","content":"Public API resources"},"180":{"id":"/docs/guides/choosing-an