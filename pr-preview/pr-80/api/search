erence/entry-points-20","page_id":"/docs/reference/entry-points","tags":[],"type":"text","url":"/docs/reference/entry-points#generator-references","content":"<Card title=\"XID\" href=\"/docs/reference/xid\" description=\"Compact identifiers compatible with rs/xid.\" />"},"345":{"id":"/docs/reference/entry-points-21","page_id":"/docs/reference/entry-points","tags":[],"type":"text","url":"/docs/reference/entry-points#generator-references","content":"<Card title=\"TSID\" href=\"/docs/reference/tsid\" description=\"Time-sorted bigint identifiers.\" />"},"346":{"id":"/docs/reference/entry-points-22","page_id":"/docs/reference/entry-points","tags":[],"type":"text","url":"/docs/reference/entry-points#generator-references","content":"<Card title=\"Errors\" href=\"/docs/reference/errors\" description=\"Typed errors and the generator list.\" />"},"347":{"id":"/docs/reference/errors","page_id":"/docs/reference/errors","type":"page","content":"Errors","breadcrumbs":["Docs","Reference"],"tags":[],"url":"/docs/reference/errors"},"348":{"id":"/docs/reference/errors-0","page_id":"/docs/reference/errors","tags":[],"type":"text","url":"/docs/reference/errors","content":"Typed, machine-readable errors for invalid input, malformed strings, and buffer bounds."},"349":{"id":"/docs/reference/errors-1","page_id":"/docs/reference/errors","type":"heading","tags":[],"url":"/docs/reference/errors#error-classes","content":"Error classes"},"350":{"id":"/docs/reference/errors-2","page_id":"/docs/reference/errors","type":"heading","tags":[],"url":"/docs/reference/errors#generator-list","content":"Generator list"},"351":{"id":"/docs/reference/errors-3","page_id":"/docs/reference/errors","tags":[],"type":"text","url":"/docs/reference/errors","content":"Every generator throws a typed error instead of a generic `Error`. Each one carries a `code` for programmatic handling and a `_tag` for discriminated matching, compatible with Effect's `catchTag`."},"352":{"id":"/docs/reference/errors-4","page_id":"/docs/reference/errors","tags":[],"type":"text","url":"/docs/reference/errors#error-classes","content":"`uniku/errors` exports four classes:"},"353":{"id":"/docs/reference/errors-5","page_id":"/docs/reference/errors","tags":[],"type":"text","url":"/docs/reference/errors#error-classes","content":"Export"},"354":{"id":"/docs/reference/errors-6","page_id":"/docs/reference/errors","tags":[],"type":"text","url":"/docs/reference/errors#error-classes","content":"`_tag`"},"355":{"id":"/docs/reference/errors-7","page_id":"/docs/reference/errors","tags":[],"type":"text","url":"/docs/reference/errors#error-classes","content":"Thrown when"},"356":{"id":"/docs/reference/errors-8","page_id":"/docs/reference/errors","tags":[],"type":"text","url":"/docs/reference/errors#error-classes","content":"`UniqueIdError`"},"357":{"id":"/docs/reference/errors-9","page_id":"/docs/reference/errors","tags":[],"type":"text","url":"/docs/reference/errors#error-classes","content":"(abstract)"},"358":{"id":"/docs/reference/errors-10","page_id":"/docs/reference/errors","tags":[],"type":"text","url":"/docs/reference/errors#error-classes","content":"Abstract base class every uniku error extends. Not thrown directly."},"359":{"id":"/docs/reference/errors-11","page_id":"/docs/reference/errors","tags":[],"type":"text","url":"/docs/reference/errors#error-classes","content":"`InvalidInputError`"},"360":{"id":"/docs/reference/errors-12","page_id":"/docs/reference/errors","tags":[],"type":"text","url":"/docs/reference/errors#error-classes","content":"`'InvalidInputError'`"},"361":{"id":"/docs/reference/errors-13","page_id":"/docs/reference/errors","tags":[],"type":"text","url":"/docs/reference/errors#error-classes","content":"Generator arguments are invalid: bad size, alphabet, length, timestamp, or version."},"362":{"id":"/docs/reference/errors-14","page_id":"/docs/reference/errors","tags":[],"type":"text","url":"/docs/reference/errors#error-classes","content":"`ParseError`"},"363":{"id":"/docs/reference/errors-15","page_id":"/docs/reference/errors","tags":[],"type":"text","url":"/docs/reference/errors#error-classes","content":"`'ParseError'`"},"364":{"id":"/docs/reference/errors-16","page_id":"/docs/reference/errors","tags":[],"type":"text","url":"/docs/reference/errors#error-classes","content":"An ID string fails to parse or decode: wrong format or characters."},"365":{"id":"/docs/reference/errors-17","page_id":"/docs/reference/errors","tags":[],"type":"text","url":"/docs/reference/errors#error-classes","content":"`BufferError`"},"366":{"id":"/docs/reference/errors-18","page_id":"/docs/reference/errors","tags":[],"type":"text","url":"/docs/reference/errors#error-classes","content":"`'BufferError'`"},"367":{"id":"/docs/reference/errors-19","page_id":"/docs/reference/errors","tags":[],"type":"text","url":"/docs/reference/errors#error-classes","content":"A byte array or buffer is too short, or an offset is out of bounds."},"368":{"id":"/docs/reference/errors-20","page_id":"/docs/reference/errors","tags":[],"type":"text","url":"/docs/reference/errors#error-classes","content":"`InvalidInputError`, `ParseError`, and `BufferError` each carry a `code: string`, a generator-prefixed constant such as `'UUID_RANDOM_BYTES_TOO_SHORT'` or `'TSID_NODE_OUT_OF_RANGE'`, plus the inherited `message: string`."},"369":{"id":"/docs/reference/errors-21","page_id":"/docs/reference/errors","tags":[],"type":"text","url":"/docs/reference/errors#error-classes","content":"Most generator modules re-export all four classes, so you rarely need to import from `uniku/errors` directly. Nanoid and CUID v2, which have no binary codec, only re-export `InvalidInputError` and `UniqueIdError`."},"370":{"id":"/docs/reference/errors-22","page_id":"/docs/reference/errors","tags":[],"type":"text","url":"/docs/reference/errors#generator-list","content":"`uniku/generators` exports the canonical, ordered list of ID kinds uniku supports:"},"371":{"id":"/docs/reference/errors-23","page_id":"/docs/reference/errors","tags":[],"type":"text","url":"/docs/reference/errors#generator-list","content":"`IdGenerator` is the union type derived from `ID_GENERATORS`. Tools that enumerate or validate generator kinds, such as `@uniku/cli`'s `--type` flag, should derive from this array instead of hand-copying the union."},"372":{"id":"/docs/reference/ksuid","page_id":"/docs/reference/ksuid","type":"page","content":"KSUID","breadcrumbs":["Docs","Reference"],"tags":[],"url":"/docs/reference/ksuid"},"373":{"id":"/docs/reference/ksuid-0","page_id":"/docs/reference/ksuid","tags":[],"type":"text","url":"/docs/reference/ksuid","content":"Time-ordered identifiers with a 128-bit random payload."},"374":{"id":"/docs/reference/ksuid-1","page_id":"/docs/reference/ksuid","tags":[],"type":"text","url":"/docs/reference/ksuid","content":"KSUID combines a timestamp with a large random payload. Choose it for high-volume distributed systems that need chronological order and a 27-character URL-safe string."},"375":{"id":"/docs/reference/nanoid","page_id":"/docs/reference/nanoid","type":"page","content":"Nanoid","breadcrumbs":["Docs","Reference"],"tags":[],"url":"/docs/reference/nanoid"},"376":{"id":"/docs/reference/nanoid-0","page_id":"/docs/reference/nanoid","tags":[],"type":"text","url":"/docs/reference/nanoid","content":"Compact, URL-safe random strings with configurable length and alphabet."},"377":{"id":"/docs/reference/nanoid-1","page_id":"/docs/reference/nanoid","tags":[],"type":"text","url":"/docs/reference/nanoid","content":"Nanoid is the compact choice for short URLs, invite codes, and session tokens. Its default alphabet is URL-safe; pass a length or options only when the boundary needs a different shape."},"378":{"id":"/docs/reference/nanoid-2","page_id":"/docs/reference/nanoid","tags":[],"type":"text","url":"/docs/reference/nanoid","content":"`nanoid.isValid()` validates the default alphabet, not values generated with a custom alphabet."},"379":{"id":"/docs/reference/objectid","page_id":"/docs/reference/objectid","type":"page","content":"ObjectID","breadcrumbs":["Docs","Reference"],"tags":[],"url":"/docs/reference/objectid"},"380":{"id":"/docs/reference/objectid-0","page_id":"/docs/reference/objectid","tags":[],"type":"text","url":"/docs/reference/objectid","content":"MongoDB-compatible 12-byte identifiers."},"381":{"id":"/docs/reference/objectid-1","page_id":"/docs/reference/objectid","tags":[],"type":"text","url":"/docs/reference/objectid","content":"ObjectID matches MongoDB's native 12-byte representation. Use it when your application stores `_id` values alongside MongoDB clients or needs to preserve that wire format."},"382":{"id":"/docs/reference/tsid","page_id":"/docs/reference/tsid","type":"page","content":"TSID","breadcrumbs":["Docs","Reference"],"tags":[],"url":"/docs/reference/tsid"},"383":{"id":"/docs/reference/tsid-0","page_id":"/docs/reference/tsid","tags":[],"type":"text","url":"/docs/reference/tsid","content":"Time-sorted 64-bit identifiers for native bigint storage."},"384":{"id":"/docs/reference/tsid-1","page_id":"/docs/reference/tsid","tags":[],"type":"text","url":"/docs/reference/tsid","content":"TSID returns a `bigint`, not a string. Use it when a database `BIGINT` primary key is the natural representation and you still need time ordering without a central allocator."},"385":{"id":"/docs/reference/typeid","page_id":"/docs/reference/typeid","type":"page","content":"TypeID","breadcrumbs":["Docs","Reference"],"tags":[],"url":"/docs/reference/typeid"},"386":{"id":"/docs/reference/typeid-0","page_id":"/docs/reference/typeid","tags":[],"type":"text","url":"/docs/reference/typeid","content":"UUID v7 identifiers with a readable, domain-specific prefix."},"387":{"id":"/docs/reference/typeid-1","page_id":"/docs/reference/typeid","tags":[],"type":"text","url":"/docs/reference/typeid","content":"TypeID wraps a UUID v7 suffix in a lowercase prefix such as `user_` or `order_`. It is useful when a public identifier should reveal the kind of resource it identifies."},"388":{"id":"/docs/reference/ulid","page_id":"/docs/reference/ulid","type":"page","content":"ULID","breadcrumbs":["Docs","Reference"],"tags":[],"url":"/docs/reference/ulid"},"389":{"id":"/docs/reference/ulid-0","page_id":"/docs/reference/ulid","tags":[],"type":"text","url":"/docs/reference/ulid","content":"Sortable, URL-safe identifiers using Crockford Base32."},"390":{"id":"/docs/reference/ulid-1","page_id":"/docs/reference/ulid","tags":[],"type":"text","url":"/docs/reference/ulid","content":"ULIDs sort by creation time and stay shorter than a hyphenated UUID. Use them when the value will often appear in URLs, logs, or APIs."},"391":{"id":"/docs/reference/uuid-v4","page_id":"/docs/reference/uuid-v4","type":"page","content":"UUID v4","breadcrumbs":["Docs","Reference"],"tags":[],"url":"/docs/reference/uuid-v4"},"392":{"id":"/docs/reference/uuid-v4-0","page_id":"/docs/reference/uuid-v4","tags":[],"type":"text","url":"/docs/reference/uuid-v4","content":"Random, standards-compatible UUIDs with 122 bits of entropy."},"393":{"id":"/docs/reference/uuid-v4-1","page_id":"/docs/reference/uuid-v4","tags":[],"type":"text","url":"/docs/reference/uuid-v4","content":"UUID v4 is the default when compatibility matters more than sort order. It fits databases and APIs that already understand UUID strings."},"394":{"id":"/docs/reference/uuid-v4-2","page_id":"/docs/reference/uuid-v4","tags":[],"type":"text","url":"/docs/reference/uuid-v4","content":"Use `toBytes()` when the destination stores UUIDs as 16-byte binary values. Use `isValid()` before accepting an unknown UUID v4 string at an application boundary."},"395":{"id":"/docs/reference/uuid-v7","page_id":"/docs/reference/uuid-v7","type":"page","content":"UUID v7","breadcrumbs":["Docs","Reference"],"tags":[],"url":"/docs/reference/uuid-v7"},"396":{"id":"/docs/reference/uuid-v7-0","page_id":"/docs/reference/uuid-v7","tags":[],"type":"text","url":"/docs/reference/uuid-v7","content":"Time-ordered UUIDs for primary keys, APIs, and event streams."},"397":{"id":"/docs/reference/uuid-v7-1","page_id":"/docs/reference/uuid-v7","tags":[],"type":"text","url":"/docs/reference/uuid-v7","content":"UUID v7 keeps the UUID shape while embedding a millisecond timestamp. It is a strong default for database primary keys when you want chronological locality without creating a custom ID column."},"398":{"id":"/docs/reference/xid","page_id":"/docs/reference/xid","type":"page","content":"XID","breadcrumbs":["Docs","Reference"],"tags":[],"url":"/docs/reference/xid"},"399":{"id":"/docs/reference/xid-0","page_id":"/docs/reference/xid","tags":[],"type":"text","url":"/docs/reference/xid","content":"Compact, time-ordered identifiers compatible with rs/xid."},"400":{"id":"/docs/reference/xid-1","page_id":"/docs/reference/xid","tags":[],"type":"text","url":"/docs/reference/xid","content":"XID is a 12-byte, lowercase base32hex identifier: a seconds-precision timestamp, a 40-bit per-runtime identity, and a shared 24-bit counter. Use it when you need Go's rs/xid wire format in a synchronous JavaScript runtime."},"401":{"id":"/docs/reference/xid-2","page_id":"/docs/reference/xid","tags":[],"type":"text","url":"/docs/reference/xid","content":"The default identity is random and cached for this runtime. Supplying `machineId` or `processId` changes only that field; calls still use the shared counter unless you also supply `counter`. Supply all four fields for deterministic output."},"402":{"id":"/docs/reference/xid-3","page_id":"/docs/reference/xid","tags":[],"type":"text","url":"/docs/reference/xid","content":"Independent runtimes choose their identity randomly, so uniqueness across them remains probabilistic rather than host-anchored as in Go's `rs/xid` implementation."}},"count":402},"sorting":{"language":"english","sortableProperties":["content","page_id","type","url"],"sortablePropertiesWithTypes":{"content":"string","page_id":"string","type":"string","url":"string"},"sorts":{"content":{"docs":{"1":155,"2":216,"3":231,"