enting them."},"241":{"id":"/docs/guides/performance-31","page_id":"/docs/guides/performance","tags":[],"type":"text","url":"/docs/guides/performance#bundle-size","content":"Every entry point is independently importable and tree-shakeable: importing `uniku/ulid` does not pull in the ULID, TypeID, or KSUID code. Minified and gzipped sizes per entry point:"},"242":{"id":"/docs/guides/performance-32","page_id":"/docs/guides/performance","tags":[],"type":"text","url":"/docs/guides/performance#bundle-size","content":"Import"},"243":{"id":"/docs/guides/performance-33","page_id":"/docs/guides/performance","tags":[],"type":"text","url":"/docs/guides/performance#bundle-size","content":"Minified + gzipped"},"244":{"id":"/docs/guides/performance-34","page_id":"/docs/guides/performance","tags":[],"type":"text","url":"/docs/guides/performance#bundle-size","content":"`uniku/ulid`"},"245":{"id":"/docs/guides/performance-35","page_id":"/docs/guides/performance","tags":[],"type":"text","url":"/docs/guides/performance#bundle-size","content":"\\~1.8 KB"},"246":{"id":"/docs/guides/performance-36","page_id":"/docs/guides/performance","tags":[],"type":"text","url":"/docs/guides/performance#bundle-size","content":"`uniku/typeid`"},"247":{"id":"/docs/guides/performance-37","page_id":"/docs/guides/performance","tags":[],"type":"text","url":"/docs/guides/performance#bundle-size","content":"\\~1.6 KB"},"248":{"id":"/docs/guides/performance-38","page_id":"/docs/guides/performance","tags":[],"type":"text","url":"/docs/guides/performance#bundle-size","content":"`uniku/uuid/v7`"},"249":{"id":"/docs/guides/performance-39","page_id":"/docs/guides/performance","tags":[],"type":"text","url":"/docs/guides/performance#bundle-size","content":"\\~1.4 KB"},"250":{"id":"/docs/guides/performance-40","page_id":"/docs/guides/performance","tags":[],"type":"text","url":"/docs/guides/performance#bundle-size","content":"`uniku/tsid`"},"251":{"id":"/docs/guides/performance-41","page_id":"/docs/guides/performance","tags":[],"type":"text","url":"/docs/guides/performance#bundle-size","content":"\\~1.4 KB"},"252":{"id":"/docs/guides/performance-42","page_id":"/docs/guides/performance","tags":[],"type":"text","url":"/docs/guides/performance#bundle-size","content":"`uniku/ksuid`"},"253":{"id":"/docs/guides/performance-43","page_id":"/docs/guides/performance","tags":[],"type":"text","url":"/docs/guides/performance#bundle-size","content":"\\~1.3 KB"},"254":{"id":"/docs/guides/performance-44","page_id":"/docs/guides/performance","tags":[],"type":"text","url":"/docs/guides/performance#bundle-size","content":"`uniku/objectid`"},"255":{"id":"/docs/guides/performance-45","page_id":"/docs/guides/performance","tags":[],"type":"text","url":"/docs/guides/performance#bundle-size","content":"\\~1.3 KB"},"256":{"id":"/docs/guides/performance-46","page_id":"/docs/guides/performance","tags":[],"type":"text","url":"/docs/guides/performance#bundle-size","content":"`uniku/xid`"},"257":{"id":"/docs/guides/performance-47","page_id":"/docs/guides/performance","tags":[],"type":"text","url":"/docs/guides/performance#bundle-size","content":"\\~1.7 KB"},"258":{"id":"/docs/guides/performance-48","page_id":"/docs/guides/performance","tags":[],"type":"text","url":"/docs/guides/performance#bundle-size","content":"`uniku/nanoid`"},"259":{"id":"/docs/guides/performance-49","page_id":"/docs/guides/performance","tags":[],"type":"text","url":"/docs/guides/performance#bundle-size","content":"\\~1.1 KB"},"260":{"id":"/docs/guides/performance-50","page_id":"/docs/guides/performance","tags":[],"type":"text","url":"/docs/guides/performance#bundle-size","content":"`uniku/uuid/v4`"},"261":{"id":"/docs/guides/performance-51","page_id":"/docs/guides/performance","tags":[],"type":"text","url":"/docs/guides/performance#bundle-size","content":"\\~1.1 KB"},"262":{"id":"/docs/guides/performance-52","page_id":"/docs/guides/performance","tags":[],"type":"text","url":"/docs/guides/performance#bundle-size","content":"`uniku/cuid/v2`