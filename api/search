"tags":[],"type":"text","url":"/docs/guides/performance#generation-speed","content":"npm is 1.1× faster"},"241":{"id":"/docs/guides/performance-29","page_id":"/docs/guides/performance","tags":[],"type":"text","url":"/docs/guides/performance#generation-speed","content":"XID"},"242":{"id":"/docs/guides/performance-30","page_id":"/docs/guides/performance","tags":[],"type":"text","url":"/docs/guides/performance#generation-speed","content":"npm is 1.7× faster"},"243":{"id":"/docs/guides/performance-31","page_id":"/docs/guides/performance","tags":[],"type":"text","url":"/docs/guides/performance#generation-speed","content":"The compatibility benchmark runs each implementation in a fresh process. CI balances both launch orders across four repetitions and reports the per-row median. The rolling action baseline keeps warmed runtime state and one noisy run from deciding the comparison."},"244":{"id":"/docs/guides/performance-32","page_id":"/docs/guides/performance","tags":[],"type":"text","url":"/docs/guides/performance#bundle-size","content":"Every entry point is independently importable and tree-shakeable: importing `uniku/ulid` does not pull in the ULID, TypeID, or KSUID code. Minified and gzipped sizes per entry point:"},"245":{"id":"/docs/guides/performance-33","page_id":"/docs/guides/performance","tags":[],"type":"text","url":"/docs/guides/performance#bundle-size","content":"Import"},"246":{"id":"/docs/guides/performance-34","page_id":"/docs/guides/performance","tags":[],"type":"text","url":"/docs/guides/performance#bundle-size","content":"Minified + gzipped"},"247":{"id":"/docs/guides/performance-35","page_id":"/docs/guides/performance","tags":[],"type":"text","url":"/docs/guides/performance#bundle-size","content":"`uniku/ulid`"},"248":{"id":"/docs/guides/performance-36","page_id":"/docs/guides/performance","tags":[],"type":"text","url":"/docs/guides/performance#bundle-size","content":"\\~1.9 KB"},"249":{"id":"/docs/guides/performance-37","page_id":"/docs/guides/perform