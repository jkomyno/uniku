d one noisy run do not decide the comparison."},"260":{"id":"/docs/guides/performance-33","page_id":"/docs/guides/performance","tags":[],"type":"text","url":"/docs/guides/performance#bundle-size","content":"Every entry point is independently importable and tree-shakeable: importing `uniku/ulid` does not pull in the ULID, TypeID, or KSUID code. Minified and gzipped sizes per entry point:"},"261":{"id":"/docs/guides/performance-34","page_id":"/docs/guides/performance","tags":[],"type":"text","url":"/docs/guides/performance#bundle-size","content":"Import"},"262":{"id":"/docs/guides/performance-35","page_id":"/docs/guides/performance","tags":[],"type":"text","url":"/docs/guides/performance#bundle-size","content":"Minified + gzipped"},"263":{"id":"/docs/guides/performance-36","page_id":"/docs/guides/performance","tags":[],"type":"text","url":"/docs/guides/performance#bundle-size","content":"`uniku/ulid`"},"264":{"id":"/docs/guides/performance-37","page_id":"/docs/guides/performance","tags":[],"type":"text","url":"/docs/guides/performance#bundle-size","content":"\\~1.9 KB"},"265":{"id":"/docs/guides/performance-38","page_id":"/docs/guides/performance","tags":[],"type":"text","url":"/docs/guides/performance#bundle-size","content":"`uniku/typeid`"},"266":{"id":"/docs/guides/performance-39","page_id":"/docs/guides/performance","tags":[],"type":"text","url":"/docs/guides/performance#bundle-size","content":"\\~2.7 KB"},"267":{"id":"/docs/guides/performance-40","page_id":"/docs/guides/performance","tags":[],"type":"text","url":"/docs/guides/performance#bundle-size","content":"`uniku/uuid/v7`"},"268":{"id":"/docs/guides/performance-41","page_id":"/docs/guides/performance","tags":[],"type":"text","url":"/docs/guides/performance#bundle-size","content":"\\~1.6 KB"},"269":{"id":"/docs/guides/performance-42","page_id":"/docs/guides/performance","tags":[],"type":"text","url":"/docs/guides/performance#bundle-size","content":"`uniku/tsid`"},"270":{"id":"/docs/guides/performance-43","pag