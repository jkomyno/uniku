{
  "$schema": "https://turborepo.org/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["build/**", "dist/**", ".source/**"]
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test:unit": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test:integration": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "bench": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "__tests__/bench/**"],
      "outputs": ["bench-results.json"]
    },
    "bench:compat": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "__tests__/bench/**", "scripts/bench-compat.ts", "scripts/bench-results.ts"],
      "outputs": ["bench-results.json"]
    },
    "bench:summary": {
      "inputs": ["bench-results.json", "scripts/bench-results.ts", "scripts/bench-summary.ts"],
      "outputs": []
    },
    "bundle:summary": {
      "dependsOn": ["^build"]
    },
    "test:e2e": {
      "dependsOn": ["^build"]
    },
    "test:e2e:cloudflare": {
      "dependsOn": ["^build"]
    },
    "build:binary": {
      "dependsOn": ["build"],
      "outputs": ["dist/**"]
    },
    "install:binary": {
      "dependsOn": ["build:binary"],
      "cache": false
    },
    "build:watch": {},
    "clean": {
      "cache": false,
      "outputs": ["packages/*/build"]
    }
  }
}
