{
  "private": true,
  "type": "module",
  "description": "Runtime-portable unique ID generators and CLI tooling",
  "repository": "https://github.com/jkomyno/uniku.git",
  "author": {
    "name": "Alberto Schiabel",
    "email": "alberto.schiabel@gmail.com"
  },
  "license": "MIT",
  "scripts": {
    "bench": "turbo run bench",
    "bench:compat": "turbo run bench:compat",
    "bench:summary": "turbo run bench:summary",
    "build:binary": "turbo run build:binary",
    "bundle:summary": "turbo run bundle:summary",
    "build": "turbo run build",
    "build:watch": "turbo run build:watch",
    "clean": "turbo run clean",
    "install:binary": "turbo run install:binary",
    "lint:ci": "biome ci",
    "lint": "biome check --fix --unsafe",
    "lint:fix": "biome check --fix --unsafe",
    "test": "pnpm -r --if-present test",
    "test:unit": "turbo run test:unit",
    "test:integration": "turbo run test:integration",
    "test:e2e": "turbo run test:e2e",
    "test:e2e:cloudflare": "turbo run test:e2e:cloudflare",
    "typecheck": "turbo run typecheck",
    "changeset": "changeset",
    "version-packages": "changeset version && pnpm install",
    "prerelease": "pnpm build",
    "release": "changeset publish",
    "prepare": "is-ci || husky"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@biomejs/biome": "^2.3.13",
    "@changesets/cli": "^2.27.10",
    "@types/node": "25.1.0",
    "@vitest/coverage-v8": "^4.0.18",
    "husky": "^9.1.7",
    "is-ci": "^4.1.0",
    "lint-staged": "^16.2.7",
    "publint": "^0.3.16",
    "rimraf": "^6.1.2",
    "tsdown": "^0.18.4",
    "tsx": "^4.21.0",
    "turbo": "^2.8.0",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "lint-staged": {
    "*.{js,ts,cjs,mjs,md,json,jsonc}": "biome check --fix --unsafe --no-errors-on-unmatched"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "packageManager": "pnpm@10.28.2"
}
