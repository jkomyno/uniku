        "import": "./build/objectid/objectid.mjs",
        "default": "./build/objectid/objectid.mjs"
      },
      "./tsid": {
        "types": "./build/tsid/tsid.d.mts",
        "import": "./build/tsid/tsid.mjs",
        "default": "./build/tsid/tsid.mjs"
