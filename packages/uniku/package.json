      },
      "./package.json": "./package.json"
    }
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "type": "module",
  "sideEffects": false,
  "files": [
    "src/**/*.ts",
    "build",
    "README.md"
  ],
  "exports": {
    "./uuid/v4": {
      "types": "./build/uuid/v4.d.mts",
      "import": {
        "@jkomyno/source": "./src/uuid/v4.ts",
        "default": "./build/uuid/v4.mjs"
      },
      "default": "./build/uuid/v4.mjs"
