{
  "private": false,
  "name": "@uniku/cli",
  "version": "0.7.0",
  "description": "CLI tool for generating and validating unique identifiers",
  "author": {
    "name": "Alberto Schiabel",
    "email": "alberto.schiabel@gmail.com",
    "url": "https://github.com/jkomyno"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jkomyno/uniku.git",
    "directory": "packages/cli"
  },
  "homepage": "https://jkomyno.github.io/uniku/docs/cli/",
  "bugs": {
    "url": "https://github.com/jkomyno/uniku/issues"
  },
  "type": "module",
  "bin": {
    "uniku": "./build/bin.mjs"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "files": [
    "build",
    "README.md"
  ],
  "scripts": {
    "clean": "rimraf build .turbo",
    "build": "tsdown --config-loader unrun",
    "build:binary": "bun scripts/build-binary.ts",
    "install:binary": "bun scripts/install-binary.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@effect/platform-bun": "4.0.0-beta.93",
    "effect": "4.0.0-beta.93",
    "uniku": "workspace:*"
  },
  "devDependencies": {
    "@effect/vitest": "4.0.0-beta.93",
    "@types/bun": "^1.3.14",
    "vitest": "catalog:"
  }
}
