{
  "private": false,
  "name": "@uniku/cli",
  "version": "0.0.12",
  "description": "CLI tool for generating and validating unique identifiers",
  "author": {
    "name": "Alberto Schiabel",
    "email": "alberto.schiabel@gmail.com",
    "url": "https://github.com/jkomyno"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jkomyno/uniku.git",
    "directory": "packages/cli"
  },
  "type": "module",
  "bin": {
    "uniku": "./build/bin.mjs"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "files": [
    "build",
    "README.md"
  ],
  "scripts": {
    "clean": "rimraf build .turbo",
    "build": "tsdown --config-loader unrun",
    "build:binary": "bun scripts/build-binary.ts",
    "install:binary": "bun scripts/install-binary.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "effect": "3.19.16",
    "@effect/cli": "0.73.2",
    "@effect/platform": "0.94.3",
    "@effect/platform-bun": "0.87.1",
    "uniku": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "^1.3.8",
    "@effect/vitest": "0.27.0",
    "vitest": "~3.2.0"
  }
}
